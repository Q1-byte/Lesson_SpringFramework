<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.zerock.account.MemberMapper">

    <!-- 회원과 권한을 함께 조회하는 ResultMap -->
    <resultMap id="memberMap" type="org.zerock.account.MemberDTO">
        <id property="userid" column="userid"/>
        <result property="userpw" column="userpw"/>
        <result property="username" column="username"/>
        <result property="enabled" column="enabled"/>
        <result property="regdate" column="regdate"/>
        <result property="updatedate" column="updatedate"/>
        <collection property="authList" ofType="org.zerock.account.AuthDTO">
            <result property="userid" column="userid"/>
            <result property="auth" column="auth"/>
        </collection>
    </resultMap>

    <!-- 회원 조회 (권한 포함) -->
    <select id="read" resultMap="memberMap">
        SELECT 
            m.userid, m.userpw, m.username, m.enabled, m.regdate, m.updatedate,
            a.auth
        FROM tmember m
        LEFT JOIN tmember_auth a ON m.userid = a.userid
        WHERE m.userid = #{userid}
    </select>

</mapper>
